# Option 1: full URL
# DATABASE_URL=postgresql+asyncpg://your_user:your_password@127.0.0.1:5432/elearndb

# Option 2: local login / individual fields
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=elearndb
DB_USER=postgres
DB_PASSWORD=postgres

# OAuth client ID used by the Flutter app to request Google ID tokens.
GOOGLE_CLIENT_ID=949329981376-3h45u3mtb8n1j4bpdkn6qdtempj3hkrc.apps.googleusercontent.com
APPLE_CLIENT_IDS=com.example.elearnApp

# Agora (the certificate must only be configured on the API server)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
LIVE_CLASS_EARLY_JOIN_MINUTES=10
LIVE_CLASS_ATTENDANCE_THRESHOLD=0.75
LIVE_CLASS_TOKEN_BUFFER_MINUTES=15
MESSAGE_MAX_LENGTH=2000
MESSAGE_MAX_FILE_SIZE_BYTES=10485760
MESSAGE_MAX_ATTACHMENTS_PER_MESSAGE=1
MESSAGE_ALLOWED_EXTENSIONS=pdf,doc,docx,ppt,pptx,xls,xlsx,txt,csv,jpg,jpeg,png
MESSAGE_RATE_LIMIT_PER_MINUTE=30
MESSAGE_CONVERSATION_RATE_LIMIT_PER_MINUTE=10
MESSAGE_UPLOAD_RATE_LIMIT_PER_10_MINUTES=10
MESSAGE_MAX_SEARCH_LENGTH=100
MESSAGE_STORAGE_BACKEND=local
MESSAGE_LOCAL_STORAGE_PATH=./private_uploads/messages
MESSAGE_ANTIVIRUS_ENABLED=false
MESSAGE_REDIS_URL=
MESSAGE_S3_BUCKET=
MESSAGE_S3_ENDPOINT_URL=
MESSAGE_S3_REGION=us-east-1
